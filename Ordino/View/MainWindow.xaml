<Window x:Class="Ordino.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ordino"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <LinearGradientBrush.RelativeTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                        <RotateTransform Angle="-90" CenterX="0.5" CenterY="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </LinearGradientBrush.RelativeTransform>
                <GradientStop Color="#FFF8D0F1"/>
                <GradientStop Color="#FFD9C9FB" Offset="1"/>
                <GradientStop Color="#FFFEFEE9" Offset="0.257"/>
                <GradientStop Color="#FFE8FCD6" Offset="0.5"/>
                <GradientStop Color="#FFC0F3C9" Offset="0.75"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="0"/>
            <ColumnDefinition Width="123*"/>
            <ColumnDefinition Width="55"/>
        </Grid.ColumnDefinitions>

        <Border Width="690"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="#FEFEE9"
                CornerRadius="12"
                Padding="36,32" Grid.Column="2" Grid.Row="1" Height="324"/>

        <Grid Width="304" Grid.Column="2" Margin="193,25,193,16" Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFCDF6CD"/>
                    <GradientStop Color="#FFF9D4F0" Offset="1"/>
                    <GradientStop Color="#FFFBFEE6" Offset="0.513"/>
                </LinearGradientBrush>
            </Grid.Background>


            <TextBlock Text="Login" 
                       FontSize="30" 
                       Foreground="Black" 
                       FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Margin="0,25,0,35"/>
            <TextBlock Text="Username" 
                       FontSize="15" 
                       Foreground="Black" 
                       HorizontalAlignment="Left"
                       Margin="20,80,0,-41"/>
            <TextBox x:Name="txtUsername" 
                     Text="{Binding CurrentUser.Username, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="20" 
                     Height="24" 
                     Width ="170" 
                     Margin=" -20,-90,-100,0"/>
            <TextBlock Text="Password" 
                       FontSize="15" 
                       Foreground="Black" 
                       HorizontalAlignment="Left"
                       Margin="20,170,0,-125"/>
            <TextBox FontSize="20" 
                     Height="24" 
                     Width ="170" 
                     Margin=" -20,80,-100,0"
                     x:Name="txtPassword" 
                       Text="{Binding CurrentUSer.Password, UpdateSourceTrigger=PropertyChanged}"
                     />
            <Button Content="Login"
                    Background="#FFD8CAFA"
                    Foreground="RosyBrown"
                    HorizontalAlignment="Center"
                    Height="30" 
                    Width="80"
                    Margin="0,200,0,0"
                    Command="{Binding LoginCommand}"
                    />
            
            
        </Grid>

    </Grid>
</Window>
