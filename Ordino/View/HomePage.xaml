<Page x:Class="Ordino.View.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ordino.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage" Height="450" Width="800">

    <Grid Background="White">
        <TextBlock Text="Main Menu" 
                FontSize="30" 
                Foreground="Black" 
                FontWeight="Medium"
                HorizontalAlignment="Center"
                Margin="0,128,0,-58"/>
        <Button Content="Login"
            Background="Gray"
            Foreground="White"
            HorizontalAlignment="Center"
            Height="30" 
            Width="80"
            Margin="0,0,0,0" Click="Button_Click"/>
        <Button Content="Content"
                Background="Gray"
                Foreground="White"
                HorizontalAlignment="Center"
                Height="30" 
                Width="80"
                Margin="0,100,0,0" Click="Button_Click_1"/>

        <Button Content="Dashboard"
            Background="Gray"
            Foreground="White"
            HorizontalAlignment="Center"
            Height="30" 
            Width="80"
            Margin="0,198,0,0" Click="Button_Click_2"/>
    </Grid>
</Page>
